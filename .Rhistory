source("./6_replica_analysis.R")
replica_analysis(resistors, techniques, resistors_df)
# ----------------------------------------------------
# Análisis del número de réplicas (potencia)
# ----------------------------------------------------
# Ejemplo: ¿Con n = 4 réplicas por técnica, qué potencia tenemos para detectar la diferencia observada entre técnica 1 y 2?
replica_analysis <- function(resistencia, tecnica, datos) {
m1 <- mean(datos$resistencia[datos$tecnica=="1"])
m2 <- mean(datos$resistencia[datos$tecnica=="2"])
sd1 <- sd(datos$resistencia[datos$tecnica=="1"])
sd2 <- sd(datos$resistencia[datos$tecnica=="2"])
sd_pooled <- sqrt(((4-1)*sd1^2 + (4-1)*sd2^2)/(4+4-2))
d_obs <- abs(m1 - m2)  # diferencia observada
print(data.frame(mean1 = m1, mean2 = m2, sd_pooled = sd_pooled, diff = d_obs))
# Potencia para t.test de dos muestras (equal var) con n = 4 por grupo
power_obs <- power.t.test(n = 4, delta = d_obs, sd = sd_pooled, sig.level = 0.05, type = "two.sample", alternative = "two.sided")
print("Potencia observada para diferencia entre técnica 1 y 2 con n=4:")
print(power_obs)
# Tamaño de muestra necesario para tener potencia = 0.8 para detectar la misma diferencia
power_req <- power.t.test(power = 0.8, delta = d_obs, sd = sd_pooled, sig.level = 0.05, type = "two.sample", alternative = "two.sided")
print("Tamaño muestral necesario por grupo (para potencia 0.8):")
print(power_req)
}
